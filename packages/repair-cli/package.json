{
  "name": "@filoz/repair-cli",
  "version": "0.1.0",
  "description": "Early repair for faulty service providers and datasets",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FilOzone/early-repair.git",
    "directory": "packages/repair-cli"
  },
  "keywords": [
    "filecoin",
    "synapse",
    "filecoin pay",
    "filecoin onchain cloud",
    "web3"
  ],
  "author": "Hugo Dias <hugomrdias@gmail.com>",
  "license": "Apache-2.0 OR MIT",
  "bugs": {
    "url": "https://github.com/FilOzone/early-repair/issues"
  },
  "homepage": "https://github.com/FilOzone/early-repair/tree/main/packages/repair-cli",
  "type": "module",
  "main": "dist/src/cli.js",
  "module": "dist/src/cli.js",
  "types": "dist/src/cli.d.ts",
  "bin": {
    "repair": "./dist/src/cli.js"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/cli.d.ts",
      "default": "./dist/src/cli.js"
    }
  },
  "files": [
    "src",
    "dist/package.json",
    "dist/src",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "wireit",
    "test": "wireit",
    "test:node": "wireit",
    "test:browser": "wireit",
    "lint": "wireit",
    "lint:fix": "biome check --fix .",
    "update:msw": "pnpx msw init test/mocks/ --save"
  },
  "wireit": {
    "build": {
      "command": "tsc --build --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "test": {
      "command": "pnpm run test:node && pnpm run test:browser",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "output": [],
      "dependencies": [
        "lint"
      ]
    },
    "test:node": {
      "command": "playwright-test \"test/**/*.test.ts\" --mode node",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "output": []
    },
    "test:browser": {
      "command": "playwright-test \"test/**/*.test.ts\" --assets ./test/mocks",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "output": []
    },
    "lint": {
      "command": "biome check .",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "../../biome.json"
      ],
      "output": [],
      "dependencies": [
        "build"
      ]
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@filoz/synapse-core": "^0.6.0",
    "@libsql/client": "^0.17.3",
    "conf": "^15.1.0",
    "drizzle-orm": "catalog:",
    "incur": "^0.4.6",
    "iso-base": "^4.4.0",
    "iso-web": "^3.1.2",
    "p-all": "^5.0.1",
    "p-locate": "^7.0.0",
    "p-map": "^7.0.4",
    "p-queue": "^9.3.0",
    "pg": "^8.21.0",
    "terminal-link": "^5.0.0",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "playwright-test": "^14.1.12",
    "type-fest": "^5.7.0",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
